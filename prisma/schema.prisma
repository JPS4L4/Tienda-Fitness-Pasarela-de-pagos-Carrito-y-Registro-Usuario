// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int       @id @default(autoincrement())
  name                     String?
  email                    String?   @unique
  phone                    String?   @unique
  emailVerified            DateTime?
  image                    String?
  password                 String? // hashed
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Perfil fitness (formulario de planes)
  weightKg                 Float?
  heightCm                 Float?
  age                       Int?
  trainingTime              String?
  goal                      String?
  equipmentAvailability     String?
  healthCondition           String?
  fitnessProfileCompleted   Boolean   @default(false)

  //Verificación de email
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  // Relaciones
  accounts  Account[]
  favorites Favorite[]
  carts     Cart[]
  reviews   Review[]
  orders    Order[]
  subscriptions UserSubscription[]
  checkoutSessions CheckoutSession[]
}

model Account {
  id                Int      @id @default(autoincrement())
  userId            Int
  provider          String // "credentials" | "google" | "facebook" | etc.
  providerAccountId String? // ID único del usuario en el proveedor OAuth
  password          String? // Solo para provider = "credentials"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([providerAccountId])
}

model Item {
  id               Int      @id @default(autoincrement())
  title            String
  description      String?
  shortDescription String?
  price            Float
  currency         String   @default("COP")
  category         String
  originalPrice    Float?
  discount         Int?
  installments     Int?
  freeShipping     Boolean? @default(false)
  images           String[]
  isOfferOfTheDay  Boolean? @default(false)
  specs            Json?
  tags             String[]
  slug             String   @unique
  stock            Int      @default(0)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  favorites Favorite[] @relation("ProductFavorites")
  cartItems CartItem[]
  reviews   Review[]
  stockAlerts StockAlert[]
}

model Plan {
  id               Int        @id @default(autoincrement())
  type             String // "nutricion" | "entrenamiento"
  title            String
  image            String?
  description      String?
  shortDescription String?
  tags             String[]
  rating           Float      @default(0)
  reviewCount      Int        @default(0)
  price            Float
  currency         String     @default("COP")
  discount         Int?
  coverage         String[]
  slug             String     @unique
  content          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relaciones
  favorites Favorite[] @relation("PlanFavorites")
  reviews   Review[]
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int? // null = anónimo
  status    String   @default("active") // active | converted | abandoned
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int?
  planId    Int?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation("ProductFavorites", fields: [productId], references: [id], onDelete: Cascade)
  plan Plan? @relation("PlanFavorites", fields: [planId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int      @default(1)
  price     Float // precio congelado
  createdAt DateTime @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CheckoutSession {
  id              String   @id @default(cuid())
  userId          Int?
  type            String // cart | plan
  status          String   @default("PENDING") // PENDING | COMPLETED | EXPIRED
  amount          Float
  currency        String   @default("COP")
  planId          Int?
  items           Json?
  shippingInfo    Json?
  paymentProvider String?
  paymentIntentId String?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

model StockAlert {
  id                Int      @id @default(autoincrement())
  productId         Int?
  requestedQuantity Int
  availableStock    Int?
  paymentProvider   String?
  paymentId         String?
  context           String?
  createdAt         DateTime @default(now())

  item Item? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([paymentId])
  @@index([createdAt])
}

model RetryEvent {
  id              Int      @id @default(autoincrement())
  paymentProvider String
  paymentId       String?
  reason          String
  context         String?
  createdAt       DateTime @default(now())

  @@index([paymentId])
  @@index([createdAt])
}
model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int?
  planId    Int?
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [productId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Order {
  id Int @id @default(autoincrement())

  userId Int? // null = compra anónima
  planId Int? // ID del plan comprado (si es suscripción)

  // Información de contacto
  customerFirstName String?
  customerLastName  String?
  customerEmail String
  customerPhone String?

  // Montos
  totalAmount Float
  status      String @default("PENDING") // PENDING | COMPLETED | CANCELLED | REFUNDED

  // Información de pago
  paymentMethod String? // STRIPE | MERCADOPAGO
  paymentId     String? // ID del pago en la pasarela

  // Dirección de envío (para productos físicos)
  shippingAddress    String?
  shippingCity       String?
  shippingState      String?
  shippingPostalCode String?

  // Snapshot del pedido
  items Json // Array de items comprados

  // Para planes/suscripciones
  accessToken        String?   @unique // Token único para acceder al plan
  tokenExpiresAt     DateTime? // Fecha de expiración del token
  subscriptionType   String? // "monthly" | "quarterly" | "yearly" | "lifetime"
  subscriptionStatus String?   @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([paymentId])
  @@index([status])
}

model UserSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  planId    Int
  orderId   Int
  
  status    String   @default("active") // active | expired | cancelled
  startDate DateTime @default(now())
  endDate   DateTime?
  
  accessToken String   @unique
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, planId, orderId])
}
