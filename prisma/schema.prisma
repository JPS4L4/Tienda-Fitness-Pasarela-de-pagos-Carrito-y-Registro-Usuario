// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int       @id @default(autoincrement())
  name                     String?
  email                    String?   @unique
  emailVerified            DateTime?
  image                    String?
  password                 String? // hashed
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  //Verificación de email
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  // Relaciones
  accounts  Account[]
  favorites Favorite[]
  carts     Cart[]
  reviews   Review[]
  orders    Order[]
}

model Account {
  id        Int      @id @default(autoincrement())
  userId    Int
  provider  String // "credentials" | "google" | "facebook" | etc.
  password  String? // Solo para provider = "credentials"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Item {
  id               Int      @id @default(autoincrement())
  title            String
  description      String?
  shortDescription String?
  price            Float
  currency         String   @default("COP")
  category         String
  originalPrice    Float?
  discount         Int?
  installments     Int?
  freeShipping     Boolean? @default(false)
  images           String[]
  isOfferOfTheDay  Boolean? @default(false)
  specs            Json?
  tags             String[]
  slug             String   @unique
  stock            Int      @default(0)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  favorites Favorite[] @relation("ProductFavorites")
  cartItems CartItem[]
  reviews   Review[]
}

model Plan {
  id               Int        @id @default(autoincrement())
  type             String // "nutricion" | "entrenamiento"
  title            String
  image            String?
  description      String?
  shortDescription String?
  tags             String[]
  rating           Float      @default(0)
  reviewCount      Int        @default(0)
  price            Float
  currency         String     @default("COP")
  discount         Int?
  coverage         String[]
  slug             String     @unique
  content          String?
  resources        Resource[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relaciones
  favorites Favorite[] @relation("PlanFavorites")
  reviews   Review[]
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int? // null = anónimo
  status    String   @default("active") // active | converted | abandoned
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model Resource {
  id             Int      @id @default(autoincrement())
  planId         Int
  type           String // "video" | "pdf" | "image" | "link" | etc.
  title          String
  url            String
  description    String?
  thumbnail      String?
  isDownloadable Boolean? @default(false)
  order          Int?     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int?
  planId    Int?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation("ProductFavorites", fields: [productId], references: [id], onDelete: Cascade)
  plan Plan? @relation("PlanFavorites", fields: [planId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int      @default(1)
  price     Float // precio congelado
  createdAt DateTime @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int?
  planId    Int?
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [productId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Order {
  id Int @id @default(autoincrement())

  userId Int? // null = compra anónima

  email String
  phone String?

  total  Float
  status String // pending | paid | shipped | delivered | cancelled

  shippingAddress Json?
  billingAddress  Json?

  items Json // snapshot del carrito

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
